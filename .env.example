# H Wallet environment variables example
# Copy this file to .env and fill in real values before local run or EAS Build.

# =========================
# Expo public runtime config
# =========================
EXPO_PUBLIC_API_BASE_URL=https://new-h-wallet-api.vercel.app
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_OWNER_NAME=
EXPO_PUBLIC_SIGNATURE_PORTAL_URL=
EXPO_PUBLIC_XLAYER_BUILDER_CODE=yf83qce657mgxsjw
EXPO_PUBLIC_OKX_CO=yf83qce657mgxsjw
EXPO_PUBLIC_CO=yf83qce657mgxsjw

# Optional fallback values used by some OKX integrations
EXPO_PUBLIC_OKX_API_KEY=
EXPO_PUBLIC_OKX_SECRET_KEY=
EXPO_PUBLIC_OKX_PASSPHRASE=

# =========================
# Server runtime config
# =========================
API_BASE_URL=https://new-h-wallet-api.vercel.app
NODE_ENV=production
PORT=3000
JWT_SECRET=
DATABASE_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# =========================
# OKX Agent Wallet
# 登录、邮箱验证码、钱包账户语义建议走 www.okx.com
# =========================
OKX_AGENT_WALLET_BASE_URL=https://www.okx.com
OKX_AGENT_WALLET_API_KEY=
OKX_AGENT_WALLET_SECRET_KEY=
OKX_AGENT_WALLET_PASSPHRASE=
OKX_AGENT_WALLET_STRICT=0
OKX_AGENT_WALLET_MOCK_OTP=123456

# =========================
# OKX DEX / Onchain OS
# 交易、报价、广播、订单查询建议走 web3.okx.com
# =========================
OKX_DEX_API_KEY=
OKX_DEX_SECRET_KEY=
OKX_DEX_PASSPHRASE=
OKX_DEX_PROJECT_ID=
OKX_DEX_STRICT=0
OKX_PROJECT_ID=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://web3.okx.com
OKX_ENV=demo
OKX_ENABLE_LIVE_GRID_TRADING=0
OKX_ALLOW_EMERGENCY_STOP=1
OKX_GRID_ALLOWED_INST_IDS=BTC-USDT-SWAP,ETH-USDT-SWAP
OKX_GRID_MAX_BUDGET_USDT=3000
OKX_GRID_MONITOR_INTERVAL_MS=60000
OKX_GRID_REBALANCE_INTERVAL_MS=3600000
OKX_GRID_MAX_DRAWDOWN_RATIO=0.1
OKX_GRID_ABNORMAL_FUNDING_RATE_THRESHOLD=0.003

# =========================
# Primary LLM / GLM 5.1
# 默认使用智谱 OpenAI 兼容接口，可按需切换为其他兼容模型
# =========================
LLM_API_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-5.1
LLM_API_KEY=
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5.1
GLM_API_KEY=
OPENAI_API_KEY=

# =========================
# Optional Manus / preview environment mapping
# =========================
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OWNER_NAME=
EXPO_WEB_PREVIEW_URL=
EXPO_PACKAGER_PROXY_URL=
APP_ENV=preview
